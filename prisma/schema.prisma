// Prisma schema for NexusAI Skills service
// Persistent storage for skill registry and execution history

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Skill represents a registered AI skill/tool
model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  capability  String   @default("general") // e.g., "code-generation", "legal-research", "data-analysis"
  tags        String[] @default([])        // e.g., ["typescript", "react", "testing"]
  content     String?                     // Full skill content/instructions
  version     String
  author      String?
  codeUrl     String?
  trustScore  Float    @default(100.0)
  permissions String[] @default([])
  status      String   @default("approved") // pending, approved, revoked
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  executions SkillExecution[]
  versions  SkillVersion[]

  @@index([name])
  @@index([status])
  @@index([capability])
}

// SkillVersion tracks skill version history for auditing
model SkillVersion {
  id        String   @id @default(cuid())
  skillId   String
  version   String
  changes   String?  // Description of changes in this version
  content   String? // Snapshot of skill content at this version
  createdAt DateTime @default(now())

  // Relations
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([version])
}

// SkillExecution tracks skill execution history for auditing
model SkillExecution {
  id          String   @id @default(cuid())
  skillId     String
  userId      String?
  toolName    String?
  status      String   // success, failed, forbidden
  error       String?
  durationMs  Int?
  input       Json?
  output      Json?
  policyCheck Json?    // Stores policy evaluation result
  createdAt   DateTime @default(now())

  // Relations
  skill Skill @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@index([skillId])
  @@index([userId])
  @@index([createdAt])
  @@index([status])
}
