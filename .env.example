# NexusAI Skills Service Configuration
# Copy this file to .env and configure for your environment

# ==============================================================================
# Server Configuration
# ==============================================================================
NODE_ENV=development
PORT=8083
HOST=0.0.0.0

# ==============================================================================
# Storage Configuration
# ==============================================================================
# Storage type: "memory" for in-memory (dev/testing) or "prisma" for PostgreSQL (production)
STORAGE_TYPE=prisma

# PostgreSQL Database URL (for Prisma storage)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://nexusai_skills:skills_secret_123@localhost:5433/skills?sslmode=disable

# ==============================================================================
# Redis Configuration
# ==============================================================================
REDIS_URL=redis://localhost:6379/3

# ==============================================================================
# CORS Configuration
# ==============================================================================
# Comma-separated list of allowed origins (leave empty for no CORS)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ==============================================================================
# Observability
# ==============================================================================
# Enable Prometheus metrics endpoint (/metrics)
METRICS_ENABLED=true

# ==============================================================================
# Security
# ==============================================================================
# API Key for service-to-service authentication
INTERNAL_API_KEY=your-internal-api-key-here

# ==============================================================================
# Logging
# ==============================================================================
LOG_LEVEL=info
